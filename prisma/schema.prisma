generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ServiceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ServiceRequestStatus {
  PENDING
  REVIEWED
  CONTACTED
  CLOSED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  avatarUrl    String?
  isActive     Boolean  @default(true)
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Role {
  id          String           @id @default(cuid())
  name        UserRole         @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@id([roleId, permissionId])
}

model Contact {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  company   String?
  subject   String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id                 String        @id @default(cuid())
  name               String
  slug               String        @unique
  shortDescription   String
  longDescription    String
  features           Json?
  status             ProductStatus @default(DRAFT)
  coverImageUrl      String?
  coverImagePublicId String?
  downloadAndroidUrl String?
  downloadIosUrl     String?
  downloadWebUrl     String?
  githubUrl          String?
  images             ProductImage[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model ProductImage {
  id            String   @id @default(cuid())
  productId     String
  imageUrl      String
  imagePublicId String
  altText       String?
  sortOrder     Int      @default(0)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Service {
  id                String        @id @default(cuid())
  title             String
  slug              String        @unique
  shortDescription  String
  content           String
  status            ServiceStatus @default(DRAFT)
  imageUrl          String?
  imagePublicId     String?
  heroTitle         String?
  heroSubtitle      String?
  heroDescription   String?
  heroImageUrl      String?
  heroImagePublicId String?
  overviewTitle     String?
  overviewContent   String?
  benefits          Json?
  featuresList      Json?
  processSteps      Json?
  faqs              Json?
  ctaTitle          String?
  ctaDescription    String?
  ctaButtonLabel    String?
  seoTitle          String?
  seoDescription    String?
  seoKeywords       Json?
  ogImageUrl        String?
  ogImagePublicId   String?
  isFeatured        Boolean       @default(false)
  sortOrder         Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model SiteSetting {
  id            String   @id @default(cuid())
  companyName   String
  supportEmail  String
  businessEmail String
  footerText    String?
  socialLinks   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ServiceRequest {
  id             String               @id @default(cuid())
  fullName       String
  email          String
  company        String?
  phoneNumber    String?
  systemName     String
  projectType    String
  description    String
  budgetMin      Decimal?             @db.Decimal(12, 2)
  budgetMax      Decimal?             @db.Decimal(12, 2)
  timeline       String?
  platforms      Json?
  features       Json?
  referenceLinks Json?
  status         ServiceRequestStatus @default(PENDING)
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}
